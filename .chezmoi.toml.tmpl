encryption = "age"
[age]
    identity = "~/key.txt"
    recipient = "age19dwad3lymtpkqr5h5m2vsj4mx2a4mufyk7jhle8le0hkxq20adxszyn9vw"
[git]
    autoCommit = true
[merge]
    command = "smerge"
    args = ["mergetool", "{{ "{{" }} .Target {{ "}}" }}", "{{ "{{" }} .Destination {{ "}}" }}", "{{ "{{" }} .Source {{ "}}" }}", "-o", "{{ "{{" }} .Source {{ "}}" }}"]
{{- $osid := .chezmoi.os -}}
{{- if hasKey .chezmoi.osRelease "id" -}}
{{-   $osid = printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id -}}
{{- end -}}
[data]
    osid = {{ $osid | quote }}

