# config
alias ec="$EDITOR ~/.zshrc"
alias ea="$EDITOR ~/.aliases"
alias rc="source ~/.zshrc"

# nvim
alias nv="nvim"

# git
alias lg="lazygit"

# files
alias cat="bat"
alias df="duf"
alias rs="rsync -axHAWXS --numeric-ids --info=progress2"

# eza
alias ls='eza --group-directories-first --git'
alias l='ls --long --header'
alias ll='ls --long --header --all'

# jless
alias yless="jless --yaml"

# rg
alias rg="rg --column --line-number --no-heading --color=always --smart-case"
alias rga="rg --hidden"
alias rgA="rg --no-ignore --hidden"
