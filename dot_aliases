# general
alias ..="j .."
alias ...="j ../.."

# nvim
alias nv="nvim"
alias nvd="neovide --fork --no-tabs"

# git
alias lg="lazygit"
alias gs="git status"
alias ga="git add"
alias gc="git commit"
alias gp="git push"
alias gpa="git push --all"
alias gpl="git pull"
alias gpla="git pull --all"

# files
alias cat="bat"
alias df="duf"
alias rs="rsync -axHAWXS --numeric-ids --info=progress2"

# eza
alias ls='eza --group-directories-first --git'
alias l='ls --long --header'
alias ll='ls --long --header --all'

# brew
alias brew-uses="brew uses --installed"

# npm
alias ncu="ncu -i --format group"
alias ncu-minor="ncu --target minor"
alias ncu-prod="ncu --dep prod"

# jless
alias yless="jless --yaml"

# jj
alias jjui="unset DEBUG && jjui"

# rg
alias rg="rg --column --line-number --no-heading --color=always --smart-case"
alias rga="rg --no-ignore --hidden"
alias rge="rga --glob '!{.git,node_modules}/*'"
