# theme = dark:"Monokai Pro Machine",light:"Monokai Pro Light"
theme = "iTerm2 Solarized Dark"
font-family = "Iosevka Nerd Font Mono"
font-size = 15
font-feature = ss05
maximize = true
window-padding-x = 5
window-padding-y = 5
window-save-state = always
mouse-hide-while-typing
macos-option-as-alt = true

# Keybindings
## General
keybind = global:alt+enter=toggle_quick_terminal
